data/history
data/market_frequencies.json
data/usage.json
raw
output
jd_reports
archive

# OS junk
Thumbs.db
desktop.ini
.DS_Store

# Docker assets (don't recurse into themselves)
Dockerfile
docker-compose.yml
.dockerignore
